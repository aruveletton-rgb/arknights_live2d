{
  "name": "arknights-vtuber-desktop-pet",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop pet client for an Arknights-style VTuber built around Open-LLM-VTuber backends.",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package": "npm run build && electron-builder --win nsis",
    "test": "vitest run",
    "selfcheck": "npm run build && npm run test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.local.arknights-vtuber-pet",
    "productName": "Arknights VTuber Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
